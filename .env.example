# Google Ads conversion (used by both phone clicks and WhatsApp clicks)
# Format: AW-XXXXXXXXX/YYYYYYYYYYY  (Conversion ID / Conversion Label)
# Leave empty to disable Ads conversion tracking; GA4 lead events still fire.
NEXT_PUBLIC_GADS_CONVERSION=

